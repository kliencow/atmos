# Atmos Global Infrastructure Configuration
# ------------------------------------------------------------------------------
# Copy this to .env to set up your primary credentials.
# Note: Sensor identity (IP/Serial/Location) is now managed via command flags.

# --- InfluxDB Connection ---
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=YOUR_SECRET_INFLUX_TOKEN_HERE
INFLUX_ORG=atmos
INFLUX_BUCKET=air_quality

# --- Application Settings ---
POLLING_INTERVAL=1m
DEBUG=false
EXIT_ON_ERROR=false

# --- Data Cleanup (Vacuum) Thresholds ---
# Max allowable change per minute before a point is considered a "spike"
VACUUM_CO2_DELTA=500
VACUUM_TEMP_DELTA=5
VACUUM_HUMIDITY_DELTA=20
VACUUM_PM25_DELTA=100
